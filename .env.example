APP_NAME=DePay
APP_ENV=development
DEMO_ENDPOINTS_ENABLED=false
REQUIRE_AUTH=false
JWT_SECRET=change_me_for_local_dev
DATABASE_URL=postgres://myuser:mypassword@localhost:5432/mydatabase?sslmode=disable
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydatabase
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
RABBITMQ_URL=amqp://myuser:mypassword@localhost:5672/
RABBITMQ_DEFAULT_USER=myuser
RABBITMQ_DEFAULT_PASS=mypassword
SKIP_RABBITMQ=true
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_RPC_TIMEOUT_MS=10000
WALLET_BALANCE_RPC_URL=
WALLET_BALANCE_RPC_TIMEOUT_MS=10000
WEBHOOK_DELIVERY_MODE=log
WEBHOOK_DELIVERY_TIMEOUT_MS=5000
GAS_PROVIDER_URL=
KYC_PROVIDER_URL=
KYC_PROVIDER_API_KEY=
KYC_PROVIDER_TIMEOUT_MS=5000
KYC_MOCK_DELAY_MS=0
VITE_API_BASE_URL=http://localhost:8090
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
VAULT_DEV_ROOT_TOKEN_ID=depay-root-token

USER_SERVICE_PORT=8080
TRANSACTION_VALIDATION_SERVICE_PORT=8081
GAS_INFO_SERVICE_PORT=8082
MERCHANT_SERVICE_PORT=8083
WALLET_SERVICE_PORT=8084
TRANSACTION_CORE_SERVICE_PORT=8085
KYC_SERVICE_PORT=8086
ADMIN_SERVICE_PORT=8090
WEB_PORT=5173
